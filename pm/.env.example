# Secrets for this workspace (gitignored). Copy to .env and fill in real values.
# These get loaded as workspace secrets during org import AND used to
# expand ${VAR} references in the channels: section of org.yaml.

# Model authentication uses the platform token flow by default. Add an optional
# BYOK value only when the selected runtime/model explicitly declares it.

# Optional Telegram credentials. Their presence does not enable the channel:
# teams/pm.yaml remains disabled until it has a nonempty literal allowed_users
# list (environment references are not expanded there; see molecule-core#4340).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
